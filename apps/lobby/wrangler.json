{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "pecking-order-lobby-dev",
  "compatibility_date": "2024-12-30",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true,
    "logs": { "invocation_logs": true, "head_sampling_rate": 1 }
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "pecking-order-lobby-db-local",
      "database_id": "local"
    }
  ],
  "r2_buckets": [
    { "binding": "PERSONA_BUCKET", "bucket_name": "pecking-order-assets-local" }
  ],
  "env": {
    "staging": {
      "name": "pecking-order-lobby-staging",
      "workers_dev": true,
      "observability": {
        "enabled": true,
        "logs": { "invocation_logs": true, "head_sampling_rate": 1, "destinations": ["axiom-logs-staging"] }
      },
      "routes": [
        { "pattern": "staging-lobby.peckingorder.ca", "custom_domain": true },
        { "pattern": "staging-playtest.peckingorder.ca", "custom_domain": true }
      ],
      "vars": {
        "GAME_SERVER_HOST": "https://staging-api.peckingorder.ca",
        "GAME_CLIENT_HOST": "https://staging-play.peckingorder.ca",
        "PERSONA_ASSETS_URL": "https://staging-assets.peckingorder.ca",
        "LOBBY_HOST": "https://staging-lobby.peckingorder.ca",
        "SESSION_COOKIE_NAME": "po_session_stg",
        "PLAYTEST_URL": "https://staging-playtest.peckingorder.ca",
        "TURNSTILE_SITE_KEY": "0x4AAAAAACyKQ25EgAbM9RSm"
      },
      "r2_buckets": [
        { "binding": "PERSONA_BUCKET", "bucket_name": "pecking-order-assets-staging" }
      ],
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "pecking-order-lobby-db-staging",
          "database_id": "9324e864-a4dc-4719-8853-3e57d41e8d1f"
        }
      ]
    },
    "production": {
      "name": "pecking-order-lobby",
      "workers_dev": true,
      "observability": {
        "enabled": true,
        "logs": { "invocation_logs": true, "head_sampling_rate": 1, "destinations": ["axiom-logs-production"] }
      },
      "routes": [
        { "pattern": "lobby.peckingorder.ca", "custom_domain": true },
        { "pattern": "playtest.peckingorder.ca", "custom_domain": true }
      ],
      "vars": {
        "GAME_SERVER_HOST": "https://api.peckingorder.ca",
        "GAME_CLIENT_HOST": "https://play.peckingorder.ca",
        "PERSONA_ASSETS_URL": "https://assets.peckingorder.ca",
        "LOBBY_HOST": "https://lobby.peckingorder.ca",
        "SESSION_COOKIE_NAME": "po_session",
        "PLAYTEST_URL": "https://playtest.peckingorder.ca",
        "TURNSTILE_SITE_KEY": "0x4AAAAAACyKQ25EgAbM9RSm"
      },
      "r2_buckets": [
        { "binding": "PERSONA_BUCKET", "bucket_name": "pecking-order-assets" }
      ],
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "pecking-order-lobby-db",
          "database_id": "f90367aa-0f60-436d-81c3-c65c342d0d4b"
        }
      ]
    }
  }
}
